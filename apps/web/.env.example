# ── Server-side only (Next.js API proxy target) ──────────────────────────────
# The browser never sees this value — all /api/* requests are transparently
# proxied by the Next.js server (see next.config.mjs rewrites).
#
# Development (API running locally):
API_URL=http://localhost:8000
#
# Docker Compose (API in the same Compose network):
# API_URL=http://api:8000

# ── Browser-visible API base ──────────────────────────────────────────────────
# Set to your FastAPI URL for direct browser→API calls (bypasses Next.js proxy).
# Leave EMPTY (or omit) to use the Next.js rewrite proxy above (recommended).
#
# Local dev (only if you want direct calls):
# NEXT_PUBLIC_API_BASE=http://localhost:8000
#
# Docker (leave empty — use API_URL proxy instead):
# NEXT_PUBLIC_API_BASE=
